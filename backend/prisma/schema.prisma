// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers UserProvider[]
  usages    BenefitUsage[]
  favorites UserFavorite[]
}

model ProviderCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String
  providers Provider[]
}

model Provider {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String
  logoUrl     String?
  category    ProviderCategory @relation(fields: [categoryId], references: [id])
  categoryId  String
  benefits    Benefit[]
  users       UserProvider[]
}

model Benefit {
  id          String   @id @default(cuid())
  title       String
  description String
  discount    String
  type        String
  category    String
  provider    Provider @relation(fields: [providerId], references: [id])
  providerId  String
  merchant    String?   // specific merchant name (e.g. "Starbucks", "Cinemark")
  location    String?   // city or region restriction
  minPurchase Int?      // minimum purchase amount in CLP
  maxDiscount Int?      // maximum discount cap in CLP
  url         String?   // link to offer details
  validUntil  DateTime?
  terms       String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  validDays   Int[]    // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat; empty=all days
  createdAt   DateTime @default(now())

  usages    BenefitUsage[]
  favorites UserFavorite[]
}

model UserProvider {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  addedAt    DateTime @default(now())

  @@unique([userId, providerId])
}

model BenefitUsage {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  benefit     Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  benefitId   String
  usedAt      DateTime @default(now())
  savedAmount Int?     // amount saved in CLP (optional, entered by user)
}

model UserFavorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  benefit   Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  benefitId String
  addedAt   DateTime @default(now())

  @@unique([userId, benefitId])
}
